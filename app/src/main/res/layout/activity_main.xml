<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bifrost_bg">

    <LinearLayout
        android:id="@+id/homeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/bifrost_screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/homeBifrostLogoView"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@string/app_name"
                    android:padding="2dp"
                    app:srcCompat="@mipmap/ic_launcher" />

                <TextView
                    android:id="@+id/homeBifrostTitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BIFROST"
                    android:textColor="@color/bifrost_text"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:ellipsize="none" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP"
                    android:textColor="@color/bifrost_text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/homeAppProfileSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    app:thumbTint="@color/bifrost_accent_light"
                    app:trackTint="@color/bifrost_surface" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/homeSettingsButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="@string/settings_gear_symbol"
                android:textColor="@color/bifrost_text"
                android:textSize="24sp"
                android:backgroundTint="@color/bifrost_surface"
                app:cornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/bifrost_accent" />
        </LinearLayout>

        <com.moonbench.bifrost.ui.LockableHorizontalScrollView
            android:id="@+id/presetCoverFlowScroll"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/presetCoverFlowContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </com.moonbench.bifrost.ui.LockableHorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/activePresetInfoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/bifrost_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/bifrost_accent"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_glow_bg"
                android:orientation="vertical"
                android:padding="@dimen/bifrost_card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/activePresetNameText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Default"
                        android:textColor="@color/bifrost_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/activePresetStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/badge_active_bg"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="ACTIVE"
                        android:textColor="@color/bifrost_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/activePresetAnimationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Animation: Static"
                    android:textColor="@color/bifrost_text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/activePresetProfileText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Profile: High"
                    android:textColor="@color/bifrost_text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.04" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/homePresetHintText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Swipe or tap a card to load a preset instantly."
            android:textColor="@color/bifrost_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/settingsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <include layout="@layout/layout_settings_panel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/closeSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:backgroundTint="@color/bifrost_surface"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="DONE"
            android:textColor="@color/bifrost_text"
            android:textSize="10sp"
            app:cornerRadius="10dp"
            app:strokeColor="@color/bifrost_accent"
            app:strokeWidth="1dp" />
    </FrameLayout>
</FrameLayout>
